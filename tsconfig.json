{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "types": [],
    "paths": {
      "pages/*": ["./pages/*"],
      "assets/*": ["./assets/*"],
      "components/*": ["./components/*"],
      "stores/*": ["./stores/*"]
    }
  },
  "include": [
    "components/**/*.ts",
    "components/**/*.vue",
    "scripts/**/*.ts",
    "pages/**/*.ts",
    "pages/**/*.vue",
    "stores/**/*.ts",
    "styles/**/*.ts",
    "env.d.ts"
  ]
}
